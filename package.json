  "type": "module",
  "main": "index.js",
  "workspaces":["client","server" ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",

    "build": "concurrently \"npm run build --workspace=server\" \"npm run build --workspace=client\"",

    "start": "concurrently -n server,client -c blue,green \"npm run start --workspace=server\" \"npm run start --workspace=client\"",

    "test": "concurrently \"npm run test --workspace=server\" \"npm run test --workspace=client\""

  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
